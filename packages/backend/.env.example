# Generation Configuration
GENERATION_MODEL=gpt-4
GENERATION_TEMPERATURE=0.3
GENERATION_MAX_TOKENS=8000
MAX_CONCURRENT_FILE_GENERATION=5
FILE_GENERATION_TIMEOUT=120000
ENABLE_TEMPLATES=true
TEMPLATES_PATH=./generation/templates

# Build Configuration
BUILD_TIMEOUT=600000
BUILD_CACHE_DIR=.build-cache
BUILD_OUTPUT_DIR=./dist
PACKAGE_MANAGER=pnpm
STRICT_LINTING=false
TYPE_CHECK_LEVEL=strict

# Deployment Configuration
DEFAULT_DEPLOY_PROVIDER=vercel
DEPLOYMENT_TIMEOUT=1800000

# Vercel Integration
VERCEL_TOKEN=your_vercel_token
VERCEL_TEAM=your_team

# Heroku Integration
HEROKU_TOKEN=your_heroku_token

# Docker Integration
DOCKER_REGISTRY_URL=docker.io
DOCKER_USERNAME=your_username
DOCKER_TOKEN=your_token

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/mags_ai_studio"
DATABASE_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# GitHub Integration
GITHUB_TOKEN=ghp_your_github_token_here

# OpenAI Integration
OPENAI_API_KEY=sk_your_openai_key
OPENAI_BASE_URL=https://api.openai.com/v1

# Server Configuration
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
JWT_SECRET=your-secret-key
JWT_EXPIRATION=15m

# Frontend URL
FRONTEND_URL=http://localhost:3000
