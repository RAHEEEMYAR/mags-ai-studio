generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// PHASES 1-8: Previous models (User, Chat, Agent, etc.)
// ============================================================================
// (All existing models from Phases 1-8 remain unchanged)

model User {
  id            String        @id @default(cuid())
  email         String        @unique @db.VarChar(255)
  username      String        @unique @db.VarChar(50)
  password      String        @db.Text
  firstName     String?       @db.VarChar(100)
  lastName      String?       @db.VarChar(100)
  avatar        String?       @db.Text
  bio           String?       @db.Text
  phone         String?       @db.VarChar(20)
  emailVerified Boolean       @default(false)
  isActive      Boolean       @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations - Phases 3-8
  userRoles      UserRole[]    @relation("UserRoles")
  sessions       Session[]     @relation("UserSessions")
  chats          Chat[]        @relation("UserChats")
  agents         Agent[]       @relation("UserAgents")
  repositories   Repository[]  @relation("UserRepositories")
  apps           GeneratedApp[] @relation("UserApps")
  securityEvents SecurityEvent[] @relation("UserSecurityEvents")

  // Relations - Phase 9
  testRuns       TestRun[]     @relation("UserTestRuns")
  bugReports     BugReport[]   @relation("UserBugReports")
  qaReports      QAReport[]    @relation("UserQAReports")

  @@index([email])
  @@index([username])
  @@map("users")
}

// (Previous models from Phases 3-8)

// ============================================================================
// PHASE 9: Testing Center System (NEW)
// ============================================================================

model TestSuite {
  id            String   @id @default(cuid())
  
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  
  // Suite configuration
  suiteType     String   @db.VarChar(50) // "unit", "integration", "e2e", "api", "load"
  targetModule  String?  @db.VarChar(100) // e.g., "auth", "chat", "agents"
  
  // Test cases
  testCaseIds   String[] @default([])
  testCount     Int      @default(0)
  
  // Status
  isActive      Boolean  @default(true)
  isAutomated   Boolean  @default(false)
  
  // Metadata
  tags          String[] @default([])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  testCases     TestCase[] @relation("SuiteTestCases")
  testRuns      TestRun[] @relation("SuiteRuns")

  @@index([suiteType])
  @@index([targetModule])
  @@index([isActive])
  @@map("test_suites")
}

model TestCase {
  id            String   @id @default(cuid())
  suiteId       String
  
  // Test details
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  testCode      String   @db.Text // The actual test code/config
  
  // Test classification
  caseType      String   @db.VarChar(50) // "happy_path", "error_case", "edge_case", "regression"
  
  // Expected outcomes
  expectedResult Json    // Expected status, assertions, etc.
  
  // Generation metadata
  isAIGenerated Boolean  @default(false)
  generatedFrom String?  @db.VarChar(255) // What it was generated from
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  suite         TestSuite @relation("SuiteTestCases", fields: [suiteId], references: [id], onDelete: Cascade)
  results       TestResult[] @relation("CaseResults")

  @@index([suiteId])
  @@index([caseType])
  @@index([isAIGenerated])
  @@map("test_cases")
}

model TestRun {
  id            String   @id @default(cuid())
  userId        String
  suiteId       String
  
  // Run configuration
  runType       String   @db.VarChar(50) // "manual", "scheduled", "ci_cd"
  parallelCount Int      @default(1) // Number of parallel workers
  
  // Execution
  status        String   @db.VarChar(50) @default("running") // running, completed, failed, aborted
  startedAt     DateTime @default(now())
  completedAt   DateTime?
  durationMs    Int?
  
  // Results
  totalTests    Int      @default(0)
  passedTests   Int      @default(0)
  failedTests   Int      @default(0)
  skippedTests  Int      @default(0)
  
  // Metadata
  environment   String?  @db.VarChar(50) // "staging", "production"
  gitCommit     String?  @db.VarChar(40)
  branch        String?  @db.VarChar(100)
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserTestRuns", fields: [userId], references: [id], onDelete: Cascade)
  suite         TestSuite @relation("SuiteRuns", fields: [suiteId], references: [id], onDelete: Cascade)
  results       TestResult[] @relation("RunResults")

  @@index([userId])
  @@index([suiteId])
  @@index([status])
  @@index([startedAt])
  @@map("test_runs")
}

model TestResult {
  id            String   @id @default(cuid())
  runId         String
  caseId        String
  
  // Result
  status        String   @db.VarChar(50) // "passed", "failed", "skipped", "error"
  
  // Details
  errorMessage  String?  @db.Text
  stackTrace    String?  @db.Text
  duration      Int?     // Duration in ms
  
  // Logs
  logs          String?  @db.Text
  stdout        String?  @db.Text
  stderr        String?  @db.Text
  
  // Assertions
  assertions    Json?    // Details about assertions
  
  // Screenshots/artifacts
  artifacts     String[] @default([]) // File paths
  
  createdAt     DateTime @default(now())

  // Relations
  run           TestRun @relation("RunResults", fields: [runId], references: [id], onDelete: Cascade)
  testCase      TestCase @relation("CaseResults", fields: [caseId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([caseId])
  @@index([status])
  @@map("test_results")
}

model BugReport {
  id            String   @id @default(cuid())
  userId        String
  
  // Bug information
  title         String   @db.VarChar(255)
  description   String   @db.Text
  
  // Classification
  severity      String   @db.VarChar(50) // "critical", "high", "medium", "low"
  status        String   @db.VarChar(50) @default("open") // "open", "investigating", "fixed", "wontfix"
  
  // Source
  source        String   @db.VarChar(50) // "automated", "manual", "user_report"
  relatedTestId String?  // If from test failure
  
  // Details
  reproducingSteps String? @db.Text
  expectedBehavior String? @db.Text
  actualBehavior String?  @db.Text
  
  // Environment
  environment   String?  @db.VarChar(50)
  affectedModule String?  @db.VarChar(100)
  
  // AI-Generated
  suggestedFix  String?  @db.Text // AI-suggested fix
  fixConfidence Float?   // 0-1: confidence of suggested fix
  
  // Tracking
  assignedTo    String?  @db.VarChar(100)
  priority      Int      @default(50) // 1-100
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  closedAt      DateTime?

  // Relations
  user          User     @relation("UserBugReports", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([severity])
  @@index([status])
  @@index([source])
  @@map("bug_reports")
}

model QAReport {
  id            String   @id @default(cuid())
  userId        String
  
  // Report information
  name          String   @db.VarChar(255)
  reportType    String   @db.VarChar(50) // "daily", "weekly", "release", "custom"
  
  // Metrics
  totalTests    Int      @default(0)
  passRate      Float    // 0-100
  failureRate   Float    // 0-100
  skipRate      Float    // 0-100
  flakiness     Float    // % of flaky tests
  
  // Coverage
  lineCoverage  Float?   // %
  branchCoverage Float?  // %
  functionCoverage Float? // %
  
  // System Health
  systemHealthScore Int?  // 0-100
  apiAvailability Float? // %
  performanceScore Int?   // 0-100
  securityScore Int?     // 0-100
  
  // Findings
  findings      Json?    // Structured findings/recommendations
  hotspots      String[] @default([]) // Problematic areas
  regressions   Int      @default(0) // Regression count
  
  // Dates
  periodStart   DateTime
  periodEnd     DateTime
  
  createdAt     DateTime @default(now())

  // Relations
  user          User     @relation("UserQAReports", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([reportType])
  @@index([periodStart])
  @@map("qa_reports")
}

model CoverageMetric {
  id            String   @id @default(cuid())
  
  // Coverage details
  filePath      String   @db.VarChar(500)
  linesCovered  Int
  linesTotal    Int
  linePercentage Float
  
  branchesCovered Int?
  branchesTotal Int?
  branchPercentage Float?
  
  functionsCovered Int?
  functionsTotal Int?
  functionPercentage Float?
  
  // Metadata
  lastUpdated   DateTime @updatedAt
  gitCommit     String?  @db.VarChar(40)
  
  createdAt     DateTime @default(now())

  @@unique([filePath, gitCommit])
  @@index([linePercentage])
  @@index([lastUpdated])
  @@map("coverage_metrics")
}

model TestMetric {
  id            String   @id @default(cuid())
  
  // Daily metrics
  date          DateTime @db.Date
  
  // Counts
  totalTests    Int
  passedTests   Int
  failedTests   Int
  flakyTests    Int
  
  // Performance
  averageDuration Float? // ms
  medianDuration Float?  // ms
  p95Duration   Float?   // ms
  
  // Trends
  passRate      Float    // %
  failureRate   Float    // %
  
  createdAt     DateTime @default(now())

  @@unique([date])
  @@index([date])
  @@index([passRate])
  @@map("test_metrics")
}